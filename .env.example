# Founder Engine — Environment Variables
# Copy this to .env and fill in your values

# === FRONTEND (Vite) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === SUPABASE EDGE FUNCTIONS (set via Supabase Dashboard > Settings > Secrets) ===
# These are NOT in .env — they live in Supabase project secrets.
# Listed here for reference only.

# Core
# SUPABASE_URL            (auto-set by Supabase)
# SUPABASE_ANON_KEY       (auto-set by Supabase)
# SUPABASE_SERVICE_ROLE_KEY (auto-set by Supabase)

# Google Drive OAuth
# GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET
# GOOGLE_REDIRECT_URI

# Stripe
# STRIPE_SECRET_KEY
# STRIPE_WEBHOOK_SECRET

# AI / LLM
# ANTHROPIC_API_KEY
# PERPLEXITY_API_KEY

# Market Intelligence (Sprint 3+)
# DATAFORSEO_LOGIN
# DATAFORSEO_PASSWORD
# NEWSAPI_KEY
# LISTENNOTES_KEY

# Integrations
# COMPOSIO_API_KEY
# RESEND_API_KEY
